# ---------------------------------------------------------------------------
# SERVER (Vercel serverless functions in /api) — set these ONLY in the
# Vercel dashboard (Project Settings -> Environment Variables). Never commit
# real values or expose them with a VITE_ prefix.
# ---------------------------------------------------------------------------

# Firebase Admin SDK service account JSON (Project Settings -> Service
# Accounts -> Generate new private key). Paste the ENTIRE JSON as one line.
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"..."}'

# Groq API key (console.groq.com) — one key, shared by /api/quiz and
# /api/moderate-chat (both import the same _groq.ts helper).
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxx"
GROQ_MODEL="llama-3.3-70b-versatile"

# Resend API key (resend.com) — used to send the OTP verification email.
# Free tier: 100 emails/day. No SMTP setup needed, just this one key.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="E.A.S Command Center <onboarding@resend.dev>"

# Supabase service_role key — ONLY if you later add server-side Supabase
# writes/admin operations. NOT used by the current /api functions.
# SUPABASE_SERVICE_ROLE_KEY="..."
